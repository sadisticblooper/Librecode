# Demo site DSL script
# 1. Deploy demo.html anywhere (Vercel, GitHub Pages, etc.)
# 2. Replace the URL below + update "url" in manifest.json

LOAD https://sadisticblooper.github.io/Sjdjd/

ON SEND
  WAIT_FOR     placeholder:Type your message
  TYPE         placeholder:Type your message  WITH $INPUT
  CLICK        aria:Send message
  WAIT_WHILE   aria:Stop generating
END

ON READ
  EXTRACT      last role:assistant
END
