LOAD https://chatgpt.com

ON LOAD
  WAIT_FOR     id:prompt-textarea
  SLEEP        2500
  EVAL         (function(){var d=document.querySelector('div[role="dialog"]');if(d){var btns=d.querySelectorAll('button');btns.forEach(function(b){if((b.innerText||'').toLowerCase().includes('accept'))b.click();});}})()
END

ON SEND
  WAIT_FOR     id:prompt-textarea
  TYPE         id:prompt-textarea  WITH $INPUT
  CLICK        aria:Send prompt
  WAIT_NEW     role:assistant
  IF_VISIBLE   aria:Close  THEN CLICK aria:Close
END

ON READ
  EXTRACT  last role:assistant
END
